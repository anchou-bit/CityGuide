<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Профиль пользователя"
        android:textSize="24sp"
        android:textColor="@color/purple_500"
        android:layout_marginBottom="32dp"
        android:gravity="center"/>

    <!-- ИЗМЕНЕНИЕ: Обёртка для аватарки с возможностью добавления фото -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/iv_avatar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/ic_profile"
            android:padding="20dp"
            android:backgroundTint="@color/purple_500"
            android:src="@drawable/ic_profile"
            android:scaleType="centerCrop"/>

        <!-- НОВЫЙ ЭЛЕМЕНТ: Кнопка для добавления/смены аватарки -->
        <Button
            android:id="@+id/btn_change_avatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="bottom|end"
            android:text="+"
            android:textSize="18sp"
            android:backgroundTint="@color/purple_500"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>
    </FrameLayout>

    <!-- НОВЫЙ ЭЛЕМЕНТ: Текст подсказки -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Нажмите + чтобы добавить фото"
        android:textSize="12sp"
        android:textColor="@color/gray"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Имя: Гость"
        android:textSize="18sp"
        android:layout_marginBottom="16dp"
        android:gravity="center"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Email: guest@example.com"
        android:textSize="18sp"
        android:layout_marginBottom="24dp"
        android:gravity="center"/>

    <Button
        android:id="@+id/btn_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Войти"
        android:backgroundTint="@color/purple_500"/>

</LinearLayout>